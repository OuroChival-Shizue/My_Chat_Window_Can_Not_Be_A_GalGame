{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GalGame Chat Studio",
  "version": "0.1.0",
  "identifier": "com.ourochival.galgamechatstudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GalGame Chat Studio - GalGame 聊天工作台",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "OuroChival-Shizue",
    "copyright": "Copyright (c) 2026 OuroChival-Shizue",
    "category": "Utility",
    "shortDescription": "GalGame 风格聊天窗口的现代桌面编辑器与运行时。",
    "longDescription": "GalGame Chat Studio 是一款 Windows 优先的 Tauri 桌面应用，用于编辑角色素材、预览布局，并运行快捷键驱动的聊天窗口渲染器。",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": true,
        "compression": "lzma",
        "startMenuFolder": "GalGame Chat Studio"
      }
    }
  }
}
